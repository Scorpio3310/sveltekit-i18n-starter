{
    "name": "sveltekit-i18n-starter",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "description": "SvelteKit i18n starter with URL localization and SEO optimization",
    "author": {
        "name": "Nik Klemenc",
        "url": "https://klemenc.si"
    },
    "homepage": "https://klemenc.si",
    "repository": {
        "type": "git",
        "url": "https://github.com/Scorpio3310/sveltekit-i18n-starter"
    },
    "license": "MIT",
    "keywords": [
        "svelte",
        "sveltekit",
        "i18n",
        "internationalization",
        "multilingual",
        "url-localization",
        "seo",
        "tailwindcss"
    ],
    "engines": {
        "node": ">=20.19"
    },
    "packageManager": "pnpm@10.26.2",
    "scripts": {
        "dev": "vite dev",
        "build": "vite build",
        "preview": "vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
        "check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "lint": "prettier --check . && eslint .",
        "format": "prettier --write ."
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@sveltejs/adapter-auto": "^7.0.1",
        "@sveltejs/kit": "^2.69.1",
        "@sveltejs/vite-plugin-svelte": "^7.1.2",
        "@tailwindcss/vite": "^4.3.2",
        "eslint": "^10.6.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.20.0",
        "globals": "^17.7.0",
        "prettier": "^3.9.4",
        "prettier-plugin-svelte": "^4.1.1",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "svelte": "^5.56.4",
        "svelte-check": "^4.7.1",
        "tailwindcss": "^4.3.2",
        "typescript": "^6.0.3",
        "vite": "^8.1.3",
        "vitest": "^4.1.9"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "esbuild"
        ]
    }
}
